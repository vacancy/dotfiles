set -e

usage() {
    cat <<EOF
Usage: pdf-compress [options] <input.pdf>

Compress a PDF using Ghostscript.

Options:
  -q, --quality <preset>   screen | ebook | printer | prepress (default: ebook)
  -o, --output <path>      output file (default: <input>_compressed.pdf)
  -h, --help               show this help

Presets:
  screen    72 dpi  — smallest, lowest quality
  ebook    150 dpi  — good balance (default)
  printer  300 dpi  — high quality
  prepress 300 dpi  — color-preserving, minimal compression
EOF
}

QUALITY="ebook"
OUTPUT=""
INPUT=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -q|--quality)
            QUALITY="$2"
            shift 2
            ;;
        -o|--output)
            OUTPUT="$2"
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        -*)
            echo "Unknown option: $1" >&2
            usage >&2
            exit 1
            ;;
        *)
            if [[ -n "$INPUT" ]]; then
                echo "Multiple input files specified." >&2
                exit 1
            fi
            INPUT="$1"
            shift
            ;;
    esac
done

if [[ -z "$INPUT" ]]; then
    echo "Input file is required." >&2
    usage >&2
    exit 1
fi

if [[ ! -f "$INPUT" ]]; then
    echo "File not found: $INPUT" >&2
    exit 1
fi

case "$QUALITY" in
    screen|ebook|printer|prepress) ;;
    *)
        echo "Invalid quality preset: $QUALITY" >&2
        usage >&2
        exit 1
        ;;
esac

if ! command -v gs >/dev/null 2>&1; then
    echo "Ghostscript (gs) not found. Install with: brew install ghostscript" >&2
    exit 1
fi

if [[ -z "$OUTPUT" ]]; then
    DIR="$(dirname "$INPUT")"
    BASE="$(basename "$INPUT" .pdf)"
    OUTPUT="$DIR/${BASE}_compressed.pdf"
fi

gs -sDEVICE=pdfwrite \
   -dCompatibilityLevel=1.4 \
   -dPDFSETTINGS=/"$QUALITY" \
   -dNOPAUSE -dQUIET -dBATCH \
   -sOutputFile="$OUTPUT" \
   "$INPUT"

IN_SIZE=$(stat -f%z "$INPUT")
OUT_SIZE=$(stat -f%z "$OUTPUT")
RATIO=$(awk "BEGIN { printf \"%.1f\", (1 - $OUT_SIZE / $IN_SIZE) * 100 }")

IN_HUMAN=$(ls -lh "$INPUT" | awk '{print $5}')
OUT_HUMAN=$(ls -lh "$OUTPUT" | awk '{print $5}')

echo "Compressed: $IN_HUMAN -> $OUT_HUMAN (${RATIO}% reduction)"
echo "Output: $OUTPUT"
